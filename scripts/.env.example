# Copy this file to `scripts/.env` (gitignored) and fill in your values.
# Then run:  source scripts/.env && ./scripts/deploy.sh

# ─── REQUIRED ────────────────────────────────────────────────────────────

# SSH host. Must be reachable as `ssh "$REMOTE"`.
# Configure your ~/.ssh/config so you can use a short alias.
export REMOTE="your-server"

# Absolute path on the remote server where the plugin folder will live.
export REMOTE_PLUGIN_DIR="/var/www/osticket/include/plugins/evolution-api"

# ─── OPTIONAL ────────────────────────────────────────────────────────────

# Owner:group to chown deployed files to (usually the web server user).
# Leave unset to skip chown.
export REMOTE_USER_GROUP="www-data:www-data"

# Database name to back up before deploying. Leave unset to skip backup.
export REMOTE_DB="osticket"

# Where the pre-deploy DB backup is written on the remote.
export REMOTE_BACKUP_DIR="/var/backups/osticket"

# Public URL of your osTicket install — only used in the "next steps" hint.
export REMOTE_OSTICKET_URL="https://your-osticket.example.com"
